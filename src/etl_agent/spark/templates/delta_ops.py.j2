from __future__ import annotations

from pyspark.sql import SparkSession, DataFrame
from pyspark.sql import functions as F
from delta import DeltaTable


# ─── Write / Create ───────────────────────────────────────────────────────────

def write_delta(
    df: DataFrame,
    path: str,
    partition_by: list[str] | None = None,
    mode: str = "{{ target.mode | default('overwrite') }}",
) -> None:
    """
    Write a DataFrame to a Delta table.

    Args:
        df: Spark DataFrame to write.
        path: Target Delta table path.
        partition_by: Optional list of partition columns.
        mode: Write mode — 'overwrite' | 'append'.
    """
    writer = df.write.format("delta").mode(mode)
    if partition_by:
        writer = writer.partitionBy(*partition_by)

    # Enable schema evolution
    writer = writer.option("mergeSchema", "true")
    writer.save(path)


# ─── Read ─────────────────────────────────────────────────────────────────────

def read_delta(spark: SparkSession, path: str, version: int | None = None) -> DataFrame:
    """
    Read from a Delta table, optionally at a specific version (time-travel).

    Args:
        spark: Active SparkSession.
        path: Delta table path.
        version: Optional Delta version for time-travel reads.
    """
    reader = spark.read.format("delta")
    if version is not None:
        reader = reader.option("versionAsOf", version)
    return reader.load(path)


# ─── Update ──────────────────────────────────────────────────────────────────

def update_delta(
    spark: SparkSession,
    path: str,
    condition: str,
    update_map: dict[str, str],
) -> None:
    """
    Update rows in a Delta table matching a condition.

    Args:
        spark: Active SparkSession.
        path: Delta table path.
        condition: SQL condition string (e.g. "status = 'pending'").
        update_map: Dict of column_name → SQL expression string.
    """
    delta_table = DeltaTable.forPath(spark, path)
    delta_table.update(
        condition=F.expr(condition),
        set={col: F.expr(expr) for col, expr in update_map.items()},
    )


# ─── Delete ──────────────────────────────────────────────────────────────────

def delete_delta(spark: SparkSession, path: str, condition: str) -> None:
    """
    Delete rows from a Delta table matching a condition.

    Args:
        spark: Active SparkSession.
        path: Delta table path.
        condition: SQL condition string (e.g. "is_deleted = true").
    """
    delta_table = DeltaTable.forPath(spark, path)
    delta_table.delete(condition=F.expr(condition))


# ─── Merge (Upsert) ──────────────────────────────────────────────────────────

def merge_delta(
    spark: SparkSession,
    source_df: DataFrame,
    target_path: str,
    merge_keys: list[str],
    update_columns: list[str] | None = None,
    insert_all: bool = True,
    delete_unmatched: bool = False,
) -> dict:
    """
    Perform a Delta merge (upsert) operation.

    Args:
        spark: Active SparkSession.
        source_df: Incoming DataFrame with new/updated records.
        target_path: Target Delta table path.
        merge_keys: Column(s) to match on (e.g. ["customer_id"]).
        update_columns: Columns to update on match (None = all columns).
        insert_all: Insert unmatched source rows (default True).
        delete_unmatched: Delete target rows not found in source (default False).

    Returns:
        Dictionary with merge operation metrics.
    """
    # Initialize Delta table (create if not exists)
    if not DeltaTable.isDeltaTable(spark, target_path):
        source_df.write.format("delta").save(target_path)
        return {"action": "initial_write", "rows": source_df.count()}

    delta_table = DeltaTable.forPath(spark, target_path)

    # Build merge condition
    merge_condition = " AND ".join(
        [f"target.{k} = source.{k}" for k in merge_keys]
    )

    # Build update set
    if update_columns:
        update_set = {col: f"source.{col}" for col in update_columns}
    else:
        update_set = {
            col.name: f"source.{col.name}"
            for col in source_df.schema
            if col.name not in merge_keys
        }

    # Execute merge
    merge_builder = (
        delta_table.alias("target")
        .merge(source_df.alias("source"), merge_condition)
        .whenMatchedUpdate(set=update_set)
    )

    if insert_all:
        merge_builder = merge_builder.whenNotMatchedInsertAll()

    if delete_unmatched:
        merge_builder = merge_builder.whenNotMatchedBySourceDelete()

    merge_builder.execute()

    return {
        "action": "merge",
        "merge_keys": merge_keys,
        "update_columns": list(update_set.keys()),
        "insert_all": insert_all,
        "delete_unmatched": delete_unmatched,
    }


# ─── Maintenance ─────────────────────────────────────────────────────────────

def optimize_delta(spark: SparkSession, path: str, z_order_cols: list[str] | None = None) -> None:
    """
    Run OPTIMIZE (and optional Z-ORDER) on a Delta table to compact small files.

    Args:
        spark: Active SparkSession.
        path: Delta table path.
        z_order_cols: Optional columns to Z-ORDER by for data skipping.
    """
    if z_order_cols:
        cols = ", ".join(z_order_cols)
        spark.sql(f"OPTIMIZE delta.`{path}` ZORDER BY ({cols})")
    else:
        spark.sql(f"OPTIMIZE delta.`{path}`")


def vacuum_delta(spark: SparkSession, path: str, retention_hours: int = 168) -> None:
    """
    Vacuum old Delta table files beyond the retention threshold.

    Args:
        spark: Active SparkSession.
        path: Delta table path.
        retention_hours: Files older than this will be deleted (default 168h = 7 days).
    """
    spark.sql(f"VACUUM delta.`{path}` RETAIN {retention_hours} HOURS")


def get_delta_history(spark: SparkSession, path: str, limit: int = 10) -> DataFrame:
    """Return the operation history of a Delta table."""
    delta_table = DeltaTable.forPath(spark, path)
    return delta_table.history(limit)
