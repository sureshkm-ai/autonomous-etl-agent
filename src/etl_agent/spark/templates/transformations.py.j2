    {% elif step.operation == "rename" %}
    # Rename columns
    {% for old_name, new_name in step.params.column_map.items() %}
    df = df.withColumnRenamed("{{ old_name }}", "{{ new_name }}")
    {% endfor %}

    {% elif step.operation == "cast" %}
    # Cast column types
    {% for col, dtype in step.params.cast_map.items() %}
    df = df.withColumn("{{ col }}", F.col("{{ col }}").cast("{{ dtype }}"))
    {% endfor %}

    {% elif step.operation == "aggregate" %}
    # Aggregate / group-by
    group_cols = [{% for c in step.params.group_by %}"{{ c }}"{% if not loop.last %}, {% endif %}{% endfor %}]
    agg_exprs = [
        {% for agg in step.params.aggregations %}
        F.{{ agg.function }}("{{ agg.column }}").alias("{{ agg.alias }}"),
        {% endfor %}
    ]
    df = df.groupBy(*group_cols).agg(*agg_exprs)

    {% elif step.operation == "join" %}
    # Join with another dataset
    # NOTE: right_df must be loaded separately if reading from a different source
