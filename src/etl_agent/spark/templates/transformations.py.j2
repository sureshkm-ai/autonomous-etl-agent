    {% if step.params.subset_cols %}
    subset_cols = [{% for c in step.params.subset_cols %}"{{ c }}"{% if not loop.last %}, {% endif %}{% endfor %}]
    df = df.dropDuplicates(subset_cols)
    {% else %}
