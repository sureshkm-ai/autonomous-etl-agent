    spark.sparkContext.setJobDescription(f"{PIPELINE_NAME} v{PIPELINE_VERSION}")

    _source = source_path or SOURCE_PATH
    _target = target_path or TARGET_PATH

    print(f"[{PIPELINE_NAME}] Reading from: {_source}")
