def run_pipeline(source_path: str | None = None, target_path: str | None = None) -> dict:
    """
    Main pipeline entry point.

    Args:
        source_path: Override source path (optional).
        target_path: Override target path (optional).

    Returns:
        Dictionary with pipeline run metadata.
    """
