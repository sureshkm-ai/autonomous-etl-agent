    print(f"[{PIPELINE_NAME}] Input row count: {df.count():,}")

    print(f"[{PIPELINE_NAME}] Applying transformations...")
    df_transformed = apply_transformations(df)

    print(f"[{PIPELINE_NAME}] Output row count: {df_transformed.count():,}")

    print(f"[{PIPELINE_NAME}] Writing to: {_target} (format={TARGET_FORMAT})")
    write_output(df_transformed)

    validation = validate_output(spark)
    print(f"[{PIPELINE_NAME}] Validation: {validation}")

    return {
        "pipeline_name": PIPELINE_NAME,
        "pipeline_version": PIPELINE_VERSION,
        "source_path": _source,
        "target_path": _target,
        "validation": validation,
        "status": "success",
    }


