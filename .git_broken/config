[core]
	repositoryformatversion = 0
	filemode = true
	bare = false
	logallrefupdates = true
	ignorecase = true
	precomposeunicode = true
[remote "origin"]
	url = https://github.com/sureshkm-ai/autonomous-etl-agent.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "main"]
	remote = origin
	merge = refs/heads/main
	vscode-merge-base = origin/main
[branch "aws_migration"]
	remote = origin
	merge = refs/heads/aws_migration
	vscode-merge-base = origin/main
[branch "governance_strategy"]
	remote = origin
	merge = refs/heads/governance_strategy
