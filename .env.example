# ═══════════════════════════════════════════════════════════════════════════════
# Autonomous ETL Agent — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ── LLM ─────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.0

# ── GitHub ───────────────────────────────────────────────────────────────────
# Personal Access Token with: repo, workflow, issues scopes
GITHUB_TOKEN=your-github-personal-access-token
# The target repo where the agent will create branches and PRs
GITHUB_TARGET_REPO=your-username/etl-pipelines-demo

# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_S3_RAW_BUCKET=etl-agent-raw
AWS_S3_PROCESSED_BUCKET=etl-agent-processed
AWS_S3_ARTIFACTS_BUCKET=etl-agent-artifacts
# LOCAL DEV ONLY: point boto3 at LocalStack. Remove this line for production.
AWS_ENDPOINT_URL=http://localstack:4566

# ── Database ─────────────────────────────────────────────────────────────────
# Dev (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./etl_agent.db
# Prod (PostgreSQL) — uncomment and fill in for production
# DATABASE_URL=postgresql+asyncpg://etl_user:etl_pass@postgres:5432/etl_agent

# ── Redis (LLM cache + Airflow Celery broker) ────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Airflow ──────────────────────────────────────────────────────────────────
AIRFLOW_API_URL=http://airflow-webserver:8080
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=admin
AIRFLOW_DAG_ID=etl_agent_pipeline

# ── API ──────────────────────────────────────────────────────────────────────
# Secret key for API key authentication
API_KEY=change-me-to-a-secure-random-string
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# ── Pipeline Behaviour ───────────────────────────────────────────────────────
# Max times the agent will retry code generation if tests fail
MAX_RETRIES=3
# Set to true to require human approval before a PR is raised
REQUIRE_HUMAN_APPROVAL=false
